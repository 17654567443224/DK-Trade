<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.dk.quant.mapper.StrategyDesMapper">
    
    <resultMap type="StrategyDes" id="StrategyDesResult">
        <result property="id"    column="id"    />
        <result property="strategyId"    column="strategy_id"    />
        <result property="strategyDescription"    column="strategy_description"    />
    </resultMap>

    <sql id="selectStrategyDesVo">
        select id, strategy_id, strategy_description from strategy_des
    </sql>

    <select id="selectStrategyDesList" parameterType="StrategyDes" resultMap="StrategyDesResult">
        <include refid="selectStrategyDesVo"/>
        <where>  
            <if test="strategyId != null "> and strategy_id = #{strategyId}</if>
            <if test="strategyDescription != null  and strategyDescription != ''"> and strategy_description = #{strategyDescription}</if>
        </where>
    </select>
    
    <select id="selectStrategyDesById" parameterType="Long" resultMap="StrategyDesResult">
        <include refid="selectStrategyDesVo"/>
        where id = #{id}
    </select>

    <insert id="insertStrategyDes" parameterType="StrategyDes" useGeneratedKeys="true" keyProperty="id">
        insert into strategy_des
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="strategyId != null">strategy_id,</if>
            <if test="strategyDescription != null">strategy_description,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="strategyId != null">#{strategyId},</if>
            <if test="strategyDescription != null">#{strategyDescription},</if>
         </trim>
    </insert>

    <update id="updateStrategyDes" parameterType="StrategyDes">
        update strategy_des
        <trim prefix="SET" suffixOverrides=",">
            <if test="strategyId != null">strategy_id = #{strategyId},</if>
            <if test="strategyDescription != null">strategy_description = #{strategyDescription},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteStrategyDesById" parameterType="Long">
        delete from strategy_des where id = #{id}
    </delete>

    <delete id="deleteStrategyDesByIds" parameterType="String">
        delete from strategy_des where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>