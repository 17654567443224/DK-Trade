<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.dk.quant.mapper.StrategyOpenPositionMapper">
    
    <resultMap type="StrategyOpenPosition" id="StrategyOpenPositionResult">
        <result property="id"    column="id"    />
        <result property="owner"    column="owner"    />
        <result property="openPositionName"    column="open_position_name"    />
        <result property="fileName"    column="file_name"    />
        <result property="className"    column="class_name"    />
        <result property="args"    column="args"    typeHandler="com.ruoyi.dk.quant.utils.MySqlJsonHandler"/>
    </resultMap>

    <sql id="selectStrategyOpenPositionVo">
        select id, owner, open_position_name, file_name, class_name, args from strategy_open_position
    </sql>

    <select id="selectStrategyOpenPositionList" parameterType="StrategyOpenPosition" resultMap="StrategyOpenPositionResult">
        <include refid="selectStrategyOpenPositionVo"/>
        <where>  
            <if test="owner != null "> and owner = #{owner}</if>
            <if test="openPositionName != null  and openPositionName != ''"> and open_position_name like concat('%', #{openPositionName}, '%')</if>
            <if test="fileName != null  and fileName != ''"> and file_name like concat('%', #{fileName}, '%')</if>
            <if test="className != null  and className != ''"> and class_name like concat('%', #{className}, '%')</if>
            <if test="args != null  and args != ''"> and args = #{args}</if>
        </where>
    </select>
    
    <select id="selectStrategyOpenPositionById" parameterType="Long" resultMap="StrategyOpenPositionResult">
        <include refid="selectStrategyOpenPositionVo"/>
        where id = #{id}
    </select>

    <insert id="insertStrategyOpenPosition" parameterType="StrategyOpenPosition" useGeneratedKeys="true" keyProperty="id">
        insert into strategy_open_position
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="owner != null">owner,</if>
            <if test="openPositionName != null and openPositionName != ''">open_position_name,</if>
            <if test="fileName != null and fileName != ''">file_name,</if>
            <if test="className != null and className != ''">class_name,</if>
            <if test="args != null">args,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="owner != null">#{owner},</if>
            <if test="openPositionName != null and openPositionName != ''">#{openPositionName},</if>
            <if test="fileName != null and fileName != ''">#{fileName},</if>
            <if test="className != null and className != ''">#{className},</if>
            <if test="args != null">#{args, typeHandler=com.ruoyi.dk.quant.utils.MySqlJsonHandler},</if>
         </trim>
    </insert>

    <update id="updateStrategyOpenPosition" parameterType="StrategyOpenPosition">
        update strategy_open_position
        <trim prefix="SET" suffixOverrides=",">
            <if test="owner != null">owner = #{owner},</if>
            <if test="openPositionName != null and openPositionName != ''">open_position_name = #{openPositionName},</if>
            <if test="fileName != null and fileName != ''">file_name = #{fileName},</if>
            <if test="className != null and className != ''">class_name = #{className},</if>
            <if test="args != null">args = #{args, typeHandler=com.ruoyi.dk.quant.utils.MySqlJsonHandler},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteStrategyOpenPositionById" parameterType="Long">
        delete from strategy_open_position where id = #{id}
    </delete>

    <delete id="deleteStrategyOpenPositionByIds" parameterType="String">
        delete from strategy_open_position where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>