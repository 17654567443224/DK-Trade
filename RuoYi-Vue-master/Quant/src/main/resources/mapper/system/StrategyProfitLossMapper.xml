<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.dk.quant.mapper.StrategyProfitLossMapper">
    
    <resultMap type="StrategyProfitLoss" id="StrategyProfitLossResult">
        <result property="id"    column="id"    />
        <result property="owner"    column="owner"    />
        <result property="profitLossName"    column="profit_loss_name"    />
        <result property="fileName"    column="file_name"    />
        <result property="className"    column="class_name"    />
        <result property="args"    column="args"    typeHandler="com.ruoyi.dk.quant.utils.MySqlJsonHandler"/>
    </resultMap>

    <sql id="selectStrategyProfitLossVo">
        select id, owner, profit_loss_name, file_name, class_name, args from strategy_profit_loss
    </sql>

    <select id="selectStrategyProfitLossList" parameterType="StrategyProfitLoss" resultMap="StrategyProfitLossResult">
        <include refid="selectStrategyProfitLossVo"/>
        <where>  
            <if test="owner != null "> and owner = #{owner}</if>
            <if test="profitLossName != null  and profitLossName != ''"> and profit_loss_name like concat('%', #{profitLossName}, '%')</if>
            <if test="fileName != null  and fileName != ''"> and file_name like concat('%', #{fileName}, '%')</if>
            <if test="className != null  and className != ''"> and class_name like concat('%', #{className}, '%')</if>
            <if test="args != null  and args != ''"> and args = #{args}</if>
        </where>
    </select>
    
    <select id="selectStrategyProfitLossById" parameterType="Long" resultMap="StrategyProfitLossResult">
        <include refid="selectStrategyProfitLossVo"/>
        where id = #{id}
    </select>

    <insert id="insertStrategyProfitLoss" parameterType="StrategyProfitLoss" useGeneratedKeys="true" keyProperty="id">
        insert into strategy_profit_loss
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="owner != null">owner,</if>
            <if test="profitLossName != null and profitLossName != ''">profit_loss_name,</if>
            <if test="fileName != null and fileName != ''">file_name,</if>
            <if test="className != null and className != ''">class_name,</if>
            <if test="args != null">args,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="owner != null">#{owner},</if>
            <if test="profitLossName != null and profitLossName != ''">#{profitLossName},</if>
            <if test="fileName != null and fileName != ''">#{fileName},</if>
            <if test="className != null and className != ''">#{className},</if>
            <if test="args != null">#{args, typeHandler=com.ruoyi.dk.quant.utils.MySqlJsonHandler},</if>
         </trim>
    </insert>

    <update id="updateStrategyProfitLoss" parameterType="StrategyProfitLoss">
        update strategy_profit_loss
        <trim prefix="SET" suffixOverrides=",">
            <if test="owner != null">owner = #{owner},</if>
            <if test="profitLossName != null and profitLossName != ''">profit_loss_name = #{profitLossName},</if>
            <if test="fileName != null and fileName != ''">file_name = #{fileName},</if>
            <if test="className != null and className != ''">class_name = #{className},</if>
            <if test="args != null">args = #{args, typeHandler=com.ruoyi.dk.quant.utils.MySqlJsonHandler},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteStrategyProfitLossById" parameterType="Long">
        delete from strategy_profit_loss where id = #{id}
    </delete>

    <delete id="deleteStrategyProfitLossByIds" parameterType="String">
        delete from strategy_profit_loss where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>