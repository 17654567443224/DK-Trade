<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.dk.quant.mapper.TargetMethodsMapper">
    
    <resultMap type="TargetMethods" id="TargetMethodsResult">
        <result property="id"    column="id"    />
        <result property="methodName"    column="method_name"    />
        <result property="parameters"    column="parameters"    typeHandler="com.ruoyi.dk.quant.utils.MySqlJsonHandler"/>
        <result property="parametersDes"    column="parameters_des"   typeHandler="com.ruoyi.dk.quant.utils.MySqlJsonHandler" />
        <result property="owner"    column="owner"    />
    </resultMap>

    <sql id="selectTargetMethodsVo">
        select id, method_name, parameters, parameters_des, owner from target_methods
    </sql>

    <select id="selectTargetMethodsList" parameterType="TargetMethods" resultMap="TargetMethodsResult">
        <include refid="selectTargetMethodsVo"/>
        <where>  
            <if test="methodName != null  and methodName != ''"> and method_name = #{methodName}</if>
            <if test="parameters != null  and parameters != ''"> and parameters = #{parameters}</if>
            <if test="parametersDes != null  and parametersDes != ''"> and parameters_des = #{parametersDes}</if>
            <if test="owner != null  and owner != ''"> and owner = #{owner}</if>
        </where>
    </select>
    
    <select id="selectTargetMethodsById" parameterType="Long" resultMap="TargetMethodsResult">
        <include refid="selectTargetMethodsVo"/>
        where id = #{id}
    </select>

    <insert id="insertTargetMethods" parameterType="TargetMethods" useGeneratedKeys="true" keyProperty="id">
        insert into target_methods
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="methodName != null and methodName != ''">method_name,</if>
            <if test="parameters != null and parameters != ''">parameters,</if>
            <if test="parametersDes != null and parametersDes != ''">parameters_des,</if>
            <if test="owner != null and owner != ''">owner,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="methodName != null and methodName != ''">#{methodName},</if>
            <if test="parameters != null and parameters != ''">#{parameters, typeHandler=com.ruoyi.dk.quant.utils.MySqlJsonHandler},</if>
            <if test="parametersDes != null and parametersDes != ''">#{parametersDes, typeHandler=com.ruoyi.dk.quant.utils.MySqlJsonHandler},</if>
            <if test="owner != null and owner != ''">#{owner},</if>
         </trim>
    </insert>

    <update id="updateTargetMethods" parameterType="TargetMethods">
        update target_methods
        <trim prefix="SET" suffixOverrides=",">
            <if test="methodName != null and methodName != ''">method_name = #{methodName},</if>
            <if test="parameters != null and parameters != ''">parameters = #{parameters, typeHandler=com.ruoyi.dk.quant.utils.MySqlJsonHandler},</if>
            <if test="parametersDes != null and parametersDes != ''">parameters_des = #{parametersDes, typeHandler=com.ruoyi.dk.quant.utils.MySqlJsonHandler},</if>
            <if test="owner != null and owner != ''">owner = #{owner},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTargetMethodsById" parameterType="Long">
        delete from target_methods where id = #{id}
    </delete>

    <delete id="deleteTargetMethodsByIds" parameterType="String">
        delete from target_methods where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>