<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.dk.quant.mapper.FunctionProfitLossMapper">
    
    <resultMap type="FunctionProfitLoss" id="FunctionProfitLossResult">
        <result property="id"    column="id"    />
        <result property="profitLossId"    column="profit_loss_id"    />
        <result property="funName"    column="fun_name"    />
        <result property="func"    column="func"    />
        <result property="args"    column="args"   typeHandler="com.ruoyi.dk.quant.utils.MySqlJsonHandler" />
    </resultMap>

    <sql id="selectFunctionProfitLossVo">
        select id, profit_loss_id, fun_name, func, args from func_profit_loss
    </sql>

    <select id="selectFunctionProfitLossList" parameterType="FunctionProfitLoss" resultMap="FunctionProfitLossResult">
        <include refid="selectFunctionProfitLossVo"/>
        <where>  
            <if test="profitLossId != null "> and profit_loss_id = #{profitLossId}</if>
            <if test="funName != null  and funName != ''"> and fun_name like concat('%', #{funName}, '%')</if>
            <if test="func != null  and func != ''"> and func = #{func}</if>
            <if test="args != null  and args != ''"> and args = #{args}</if>
        </where>
    </select>
    
    <select id="selectFunctionProfitLossById" parameterType="Long" resultMap="FunctionProfitLossResult">
        <include refid="selectFunctionProfitLossVo"/>
        where id = #{id}
    </select>

    <insert id="insertFunctionProfitLoss" parameterType="FunctionProfitLoss" useGeneratedKeys="true" keyProperty="id">
        insert into func_profit_loss
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="profitLossId != null">profit_loss_id,</if>
            <if test="funName != null and funName != ''">fun_name,</if>
            <if test="func != null and func != ''">func,</if>
            <if test="args != null">args,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="profitLossId != null">#{profitLossId},</if>
            <if test="funName != null and funName != ''">#{funName},</if>
            <if test="func != null and func != ''">#{func},</if>
            <if test="args != null">#{args, typeHandler=com.ruoyi.dk.quant.utils.MySqlJsonHandler},</if>
         </trim>
    </insert>

    <update id="updateFunctionProfitLoss" parameterType="FunctionProfitLoss">
        update func_profit_loss
        <trim prefix="SET" suffixOverrides=",">
            <if test="profitLossId != null">profit_loss_id = #{profitLossId},</if>
            <if test="funName != null and funName != ''">fun_name = #{funName},</if>
            <if test="func != null and func != ''">func = #{func},</if>
            <if test="args != null">args = #{args, typeHandler=com.ruoyi.dk.quant.utils.MySqlJsonHandler},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteFunctionProfitLossById" parameterType="Long">
        delete from func_profit_loss where id = #{id}
    </delete>

    <delete id="deleteFunctionProfitLossByIds" parameterType="String">
        delete from func_profit_loss where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>